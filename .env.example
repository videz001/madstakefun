# Postgres connection string (Prisma). Local example below; for hosted DBs
# (Supabase/Neon/Railway) paste their connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cosmos_fast_pass?schema=public

# Secret used to sign session JWTs. Generate: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-string

# Cosmos Hub
NEXT_PUBLIC_COSMOS_CHAIN_ID=cosmoshub-4
# Public LCD/REST endpoint (no node required). Examples:
#   https://cosmos-rest.publicnode.com
#   https://rest.cosmos.directory/cosmoshub
COSMOS_LCD_URL=https://cosmos-rest.publicnode.com

# Public Tendermint RPC endpoint (used by CosmJS to broadcast the stake tx).
# Must be NEXT_PUBLIC_ since signing/broadcast happens in the browser. Examples:
#   https://cosmos-rpc.publicnode.com
#   https://rpc.cosmos.directory/cosmoshub
NEXT_PUBLIC_COSMOS_RPC_URL=https://cosmos-rpc.publicnode.com

# X (Twitter) OAuth 2.0 app (paid; create at developer.x.com)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/auth/x/callback

# Admin gate for /admin and the CSV export. Use a long random string.
ADMIN_KEY=replace-me-with-a-long-random-string
